# Server environment variables
# Copy to server/.env and fill in values before running locally or deploying.

PORT=3000

# PostgreSQL (required when AUTH_MODE=database)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/intracom?schema=public

# Redis (optional — used for Socket.IO adapter)
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Feature flags
# -----------------------------------------------------------------------------

# Master switch for the auth API (login, /me, /status)
FEATURE_AUTH_ENABLED=true

# Auth validation mode:
#   mock     — accepts any email/password (local UI testing only)
#   env      — validates against ADMIN_SEED_* below (no database required)
#   database — validates against AdminUser table in PostgreSQL
AUTH_MODE=env

# When true, admin sockets must present a valid JWT (handshake auth.token)
FEATURE_SOCKET_AUTH=false

# REST inbox API for admin dashboard (GET /api/conversations, messages)
FEATURE_CHAT_API=true

# Persist conversations and messages to PostgreSQL (requires DATABASE_URL)
FEATURE_CHAT_PERSISTENCE=true

# Default tenant/app id for widget conversations
DEFAULT_APP_ID=default

# Analytics REST API for admin dashboard
FEATURE_STATS_API=true

# Visitor profiles REST API (linked to conversations)
FEATURE_VISITORS_API=true

# -----------------------------------------------------------------------------
# JWT
# -----------------------------------------------------------------------------

AUTH_JWT_SECRET=change-me-in-production-use-long-random-string
AUTH_JWT_EXPIRES_IN=7d

# -----------------------------------------------------------------------------
# Seed admin (used by AUTH_MODE=env and initial database seed)
# -----------------------------------------------------------------------------

ADMIN_SEED_EMAIL=admin@intracom.com
ADMIN_SEED_PASSWORD=changeme
ADMIN_SEED_NAME=Admin User
